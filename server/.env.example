PORT=4001
BACKEND_URL=https://soupcircle-backend.vercel.app
# 首页「调用后端 /hello」需要远端提供 GET /hello（例如纯文本 hello world）
# 后端若挂在根路径而非 /api，设为 true
# BACKEND_STRIP_API_PREFIX=true
# 生产环境可限制来源，逗号分隔
# CORS_ORIGIN=http://localhost:5173
# Admin token cookie 配置
ADMIN_TOKEN_COOKIE_NAME=admin_token
ADMIN_COOKIE_MAX_AGE_MS=604800000
ADMIN_COOKIE_SECURE=true
